---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate, getPublishedPosts, sitePath } from '../lib/posts';
import { getCategory } from '../data/categories';

const posts = await getPublishedPosts();
const grouped = posts.reduce<Record<string, typeof posts>>((acc, post) => {
  const year = String(post.data.pubDate.getFullYear());
  acc[year] ??= [];
  acc[year].push(post);
  return acc;
}, {});
---

<BaseLayout title="归档" description="iNote 的全部文章时间线。">
  <section class="page-hero page-hero--compact">
    <p class="eyebrow">Archive</p>
    <h1>归档</h1>
    <p>按年份查看全部文章，适合回看一段时间里的关注点如何变化。</p>
  </section>
  <section class="archive-shell">
    {
      Object.entries(grouped).map(([year, items]) => (
        <section class="archive-year">
          <h2>{year}</h2>
          <div class="archive-list">
            {items.map((post) => {
              const category = getCategory(post.data.category);
              return (
                <a href={sitePath(`posts/${post.slug}/`)} style={`--accent:${category?.accent ?? '#777'}`}>
                  <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                  <strong>{post.data.title}</strong>
                  {category && <span>{category.name}</span>}
                </a>
              );
            })}
          </div>
        </section>
      ))
    }
  </section>
</BaseLayout>
