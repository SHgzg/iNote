---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import GitHubComments from '../../components/GitHubComments.astro';
import { getCategory } from '../../data/categories';
import { assetPath, formatDate, getPublishedPosts, readingMinutes, sitePath, slugifyTag } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const category = getCategory(post.data.category);
const tocItems = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const related = (await getPublishedPosts())
  .filter((item) => item.id !== post.id && item.data.category === post.data.category)
  .slice(0, 3);
---

<BaseLayout title={post.data.title} description={post.data.description} image={assetPath(post.data.heroImage)}>
  <article class="article-page" style={`--accent:${category?.accent ?? '#777'}`}>
    <header class="article-header">
      <div class="article-kicker">
        {category && <a href={sitePath(`categories/${category.slug}/`)}>{category.name}</a>}
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span>{readingMinutes(post.body)} 分钟</span>
      </div>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      {
        post.data.tags.length > 0 && (
          <div class="tag-list tag-list--large">
            {post.data.tags.map((tag) => (
              <a href={sitePath(`tags/${slugifyTag(tag)}/`)}>{tag}</a>
            ))}
          </div>
        )
      }
    </header>
    <div class="article-body">
      <div class="article-content">
        <div class="prose">
          <Content />
        </div>
        <GitHubComments repo="SHgzg/iNote" />
      </div>
      {
        tocItems.length > 0 && (
          <aside class="article-toc" aria-labelledby="article-toc-title">
            <div class="article-toc__header">
              <p class="eyebrow">目录</p>
              <h2 id="article-toc-title">标题导航</h2>
            </div>
            <nav class="article-toc__nav" aria-label="文章目录" data-article-toc>
              <ol>
                {tocItems.map((heading) => (
                  <li class={`article-toc__item article-toc__item--depth-${heading.depth}`}>
                    <a href={`#${heading.slug}`} data-article-toc-link>
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </aside>
        )
      }
    </div>
  </article>
  {
    related.length > 0 && (
      <section class="section-shell article-related">
        <div class="section-heading">
          <p class="eyebrow">Related</p>
          <h2>同栏目继续读</h2>
        </div>
        <div class="post-grid">
          {related.map((item) => <ArticleCard post={item} mode="compact" />)}
        </div>
      </section>
    )
  }
</BaseLayout>

<script is:inline>
  (() => {
    const nav = document.querySelector('[data-article-toc]');
    if (!nav) return;

    const links = Array.from(nav.querySelectorAll('[data-article-toc-link]'));
    const headings = links
      .map((link) => document.getElementById(link.getAttribute('href')?.slice(1) || ''))
      .filter((heading) => heading instanceof HTMLElement);

    if (!links.length || !headings.length) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const setActive = (id) => {
      links.forEach((link) => {
        const isActive = link.getAttribute('href') === `#${id}`;
        if (isActive) {
          link.setAttribute('aria-current', 'true');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    const initialTarget = document.getElementById(window.location.hash.slice(1));
    setActive(initialTarget?.id || headings[0].id);

    links.forEach((link) => {
      link.addEventListener('click', (event) => {
        const href = link.getAttribute('href');
        if (!href?.startsWith('#')) return;

        const target = document.getElementById(href.slice(1));
        if (!target) return;

        event.preventDefault();
        setActive(target.id);
        history.pushState(null, '', href);
        target.scrollIntoView({
          behavior: prefersReducedMotion ? 'auto' : 'smooth',
          block: 'start'
        });
      });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

        if (visible.length > 0) {
          const activeTarget = visible[0].target;
          if (activeTarget instanceof HTMLElement) {
            setActive(activeTarget.id);
          }
        }
      },
      {
        rootMargin: '-20% 0px -68% 0px',
        threshold: 0
      }
    );

    headings.forEach((heading) => observer.observe(heading));
  })();
</script>
