---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getPublishedPosts, slugifyTag } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = new Map<string, string>();

  for (const post of posts) {
    for (const tag of post.data.tags) {
      tags.set(slugifyTag(tag), tag);
    }
  }

  return Array.from(tags.entries()).map(([slug, tag]) => ({
    params: { tag: slug },
    props: { tag }
  }));
}

const { tag } = Astro.props;
const posts = (await getPublishedPosts()).filter((post) => post.data.tags.includes(tag));
---

<BaseLayout title={`标签：${tag}`} description={`iNote 中带有 ${tag} 标签的文章。`}>
  <section class="page-hero page-hero--compact">
    <p class="eyebrow">Tag</p>
    <h1>{tag}</h1>
    <p>{posts.length} 篇文章使用了这个标签。</p>
  </section>
  <section class="section-shell">
    <div class="post-list">
      {posts.map((post) => <ArticleCard post={post} />)}
    </div>
  </section>
</BaseLayout>
