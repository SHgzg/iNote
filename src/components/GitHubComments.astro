---
type Props = {
  repo: string;
};

const { repo } = Astro.props;
---

<section class="comments-shell" aria-labelledby="comments-title">
  <div class="comments-heading">
    <p class="eyebrow">Comments</p>
    <h2 id="comments-title">评论</h2>
  </div>
  <div class="comments-frame" data-github-comments data-repo={repo}></div>
</section>

<script is:inline>
  (() => {
    const container = document.querySelector('[data-github-comments]');
    if (!container || container.dataset.loaded === 'true') return;

    const getTheme = () =>
      document.documentElement.dataset.theme === 'dark' ? 'github-dark' : 'github-light';

    const script = document.createElement('script');
    script.src = 'https://utteranc.es/client.js';
    script.async = true;
    script.crossOrigin = 'anonymous';
    script.setAttribute('repo', container.dataset.repo || '');
    script.setAttribute('issue-term', 'pathname');
    script.setAttribute('theme', getTheme());

    container.dataset.loaded = 'true';
    container.appendChild(script);

    const syncTheme = () => {
      const frame = container.querySelector('iframe.utterances-frame');
      frame?.contentWindow?.postMessage(
        {
          type: 'set-theme',
          theme: getTheme()
        },
        'https://utteranc.es'
      );
    };

    new MutationObserver(syncTheme).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme']
    });

    script.addEventListener('load', () => window.setTimeout(syncTheme, 500));
  })();
</script>
