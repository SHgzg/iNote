---
import type { Post } from '../lib/posts';
import { formatDate, readingMinutes, sitePath, slugifyTag } from '../lib/posts';
import { getCategory } from '../data/categories';

type Props = {
  post: Post;
  mode?: 'default' | 'compact' | 'feature';
};

const { post, mode = 'default' } = Astro.props;
const category = getCategory(post.data.category);
const minutes = readingMinutes(post.body);
---

<article class:list={['article-card', `article-card--${mode}`]} style={`--accent:${category?.accent ?? '#777'}`}>
  <div class="article-card__body">
    <div class="article-card__meta">
      {category && <a href={sitePath(`categories/${category.slug}/`)}>{category.name}</a>}
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
      <span>{minutes} 分钟</span>
    </div>
    <h2>
      <a href={sitePath(`posts/${post.slug}/`)}>{post.data.title}</a>
    </h2>
    <p>{post.data.description}</p>
    {
      post.data.tags.length > 0 && (
        <div class="tag-list" aria-label="标签">
          {post.data.tags.slice(0, 4).map((tag) => (
            <a href={sitePath(`tags/${slugifyTag(tag)}/`)}>{tag}</a>
          ))}
        </div>
      )
    }
  </div>
</article>
